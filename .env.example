# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini API (free key from aistudio.google.com) — used for intent parsing.
# If absent, the app falls back to a heuristic parser.
GOOGLE_GENERATIVE_AI_API_KEY=

# Encryption — base64 string decoding to exactly 32 bytes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your_base64_encoded_32_byte_key
# Session signing secret (recommended, falls back to ENCRYPTION_KEY if unset)
AUTH_SESSION_SECRET=
# OTP hashing secret (recommended, falls back to AUTH_SESSION_SECRET/ENCRYPTION_KEY)
OTP_SECRET=

# --- OAuth Providers ---
# Slack: create an app at api.slack.com/apps. Add bot scopes chat:write, users:read.
# Set the OAuth redirect URL to: ${NEXT_PUBLIC_APP_URL}/api/oauth/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Google: create OAuth credentials at console.cloud.google.com (one app covers
# both Calendar and Gmail). Enable the Calendar API and Gmail API.
# Authorized redirect URIs (add BOTH):
#   ${NEXT_PUBLIC_APP_URL}/api/oauth/google-calendar/callback
#   ${NEXT_PUBLIC_APP_URL}/api/oauth/google-gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional OTP email delivery via Resend
RESEND_API_KEY=
OTP_FROM_EMAIL=onboarding@your-domain.com

# Optional model override for intent parsing
GOOGLE_MODEL=gemini-2.0-flash

# Optional: generic outbound API/webhook actions (v2 plugin)
# Comma-separated host allowlist for action "http.request"
HTTP_ACTION_ALLOWLIST=

# Optional: browser automation allowlist (comma-separated hosts).
# If empty, browser.open_url can navigate to any http/https host.
BROWSER_ACTION_ALLOWLIST=

# Optional: constrain path-based OS actions to a sandbox root
OS_ACTION_SANDBOX_ROOT=

# Optional v2 orchestration tuning
V2_STEP_TIMEOUT_MS=30000
V2_STEP_MAX_RETRIES=1
V2_RUN_RATE_LIMIT_WINDOW_SECONDS=60
V2_RUN_RATE_LIMIT_MAX=20

# Optional: IANA timezone for calendar events when Gemini fallback parses times
# (defaults to the server local timezone). Example: Asia/Kolkata
CALENDAR_DEFAULT_TIMEZONE=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
